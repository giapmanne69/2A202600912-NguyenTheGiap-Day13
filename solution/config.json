{
  "provider": "openai",
  "model": "openai/gpt-oss-120b:free",
  "model_price_tier": "standard",
  "max_steps": 10,
  "loop_guard": true,
  "temperature": 0.2,
  "context_size": 5,
  "verbose_system": false,
  "timeout_ms": 10000,
  "max_completion_tokens": 800,
  "retry": {"enabled": true, "max_attempts": 3, "backoff_ms": 500},
  "cache": {"enabled": true},
  "normalize_unicode": true,
  "redact_pii": true,
  "session_drift_rate": 0.0,
  "context_reset_every": 3,
  "tool_error_rate": 0.0,
  "catalog_override": {},
  "route_rules": [],
  "planner": false,
  "verify": true,
  "self_consistency": 1,
  "tool_budget": 4
}
